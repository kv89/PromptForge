# Google Cloud Platform project ID
GCP_PROJECT_ID=your-gcp-project-id

# Firebase project ID (used for auth token verification)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Absolute path to the GCP service account credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Runtime environment: dev or prod
ENVIRONMENT=dev

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Vertex AI (set MODEL_PROVIDER=vertexai to use)
VERTEXAI_LOCATION=us-central1
VERTEXAI_DEFAULT_MODEL=gemini-2.0-flash
VERTEXAI_JUDGE_MODEL=gemini-2.0-flash
JUDGE_PROVIDER=ollama

GEMINI_API_KEY=
